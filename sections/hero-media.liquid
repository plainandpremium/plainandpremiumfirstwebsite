<section class="hero-media" style="--hero-height: {{ section.settings.hero_height }}vh;">
  <div class="hero-media__background">
    {%- assign media_type = section.settings.media_type -%}
    {% if media_type == 'image' and section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 2200 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {% elsif media_type == 'video' and section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          image_size: '2000x'
      }}
    {% elsif section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 2200 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {% elsif section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          image_size: '2000x'
      }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-media__placeholder' }}
    {% endif %}
  </div>

  <div class="hero-media__overlay page-width">
    {% if section.settings.top_text != blank %}
      <p class="hero-media__top-text">{{ section.settings.top_text }}</p>
    {% endif %}

    <div class="hero-media__content">
      <h1>{{ section.settings.title }}</h1>
      {% if section.settings.subtitle != blank %}
        <p>{{ section.settings.subtitle }}</p>
      {% endif %}
      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a class="button button--light" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero media",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "video",
      "info": "Choose what to display in the hero. Upload the matching file below."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Used when Media type is Image."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Hero video",
      "info": "Used when Media type is Video."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Top text",
      "default": "We are starting with the most premium black and white t-shirts."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "plain and premium"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "premium made affordable"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Hero height",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Hero media"
    }
  ]
}
{% endschema %}
