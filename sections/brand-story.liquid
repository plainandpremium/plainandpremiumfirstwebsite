<section class="brand-story">
  <div class="page-width brand-story__inner">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.description }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Idea"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "plain and premium creates timeless clothing built around simplicity, fit, and comfort."
    }
  ],
  "presets": [
    {
      "name": "Brand story"
    }
  ]
}
{% endschema %}
