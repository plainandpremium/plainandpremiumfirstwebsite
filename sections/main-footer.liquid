{%- assign _abase = routes.account_url | split: '?' | first | split: '#' | first | remove: '/orders' | remove: '/profile' -%}
{%- assign _atail = _abase | slice: -1, 1 -%}
{%- if _atail == '/' -%}
  {%- assign _alen = _abase.size | minus: 1 -%}
  {%- assign _abase = _abase | slice: 0, _alen -%}
{%- endif -%}
{%- assign customer_profile_url = _abase | append: '/profile' -%}

<footer class="site-footer">
  <div class="page-width site-footer__grid">
    <div class="site-footer__brand">
      <p class="site-footer__logo">{{ section.settings.brand_text }}</p>
      {% if section.settings.tagline != blank %}
        <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
      {% endif %}
    </div>

    <div class="site-footer__column">
      <h2 class="site-footer__heading">Shop</h2>
      <ul class="site-footer__links">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><a href="{{ routes.root_url }}#featured-products">Products</a></li>
        <li><a href="{{ routes.cart_url }}">Cart</a></li>
      </ul>
    </div>

    <div class="site-footer__column">
      <h2 class="site-footer__heading">Account</h2>
      <ul class="site-footer__links">
        {% if customer %}
          <li><a href="{{ customer_profile_url }}">My profile</a></li>
          <li><a href="{{ routes.account_logout_url }}">Log out</a></li>
        {% else %}
          <li>
            {%- assign _signin_return = routes.root_url | append: '?goto=profile' -%}
            <a
              href="{{ routes.account_login_url }}?return_to={{ _signin_return | url_encode }}"
              data-signin-redirect
            >Sign in</a>
          </li>
        {% endif %}
      </ul>
    </div>

    <div class="site-footer__column">
      <h2 class="site-footer__heading">Contact</h2>
      <ul class="site-footer__links">
        {% if section.settings.contact_email != blank %}
          <li><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></li>
        {% elsif shop.email != blank %}
          <li><a href="mailto:{{ shop.email }}">{{ shop.email }}</a></li>
        {% endif %}
        {% if shop.privacy_policy %}
          <li><a href="{{ shop.privacy_policy.url }}">Privacy policy</a></li>
        {% endif %}
        {% if shop.refund_policy %}
          <li><a href="{{ shop.refund_policy.url }}">Refund policy</a></li>
        {% endif %}
        {% if shop.terms_of_service %}
          <li><a href="{{ shop.terms_of_service.url }}">Terms of service</a></li>
        {% endif %}
      </ul>
    </div>
  </div>

  <div class="page-width site-footer__bottom">
    <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</small>
  </div>
</footer>

{% schema %}
{
  "name": "Main footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand name",
      "default": "Look classy"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "money ≠ class."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "info": "Leave blank to use your store email."
    }
  ],
  "presets": [
    {
      "name": "Main footer"
    }
  ]
}
{% endschema %}
